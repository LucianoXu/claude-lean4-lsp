{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "claude-lean4-lsp",
  "description": "Lean 4 language server plugin for Claude Code — enables diagnostics, hover info, go-to-definition, and completions for interactive theorem proving in .lean files",
  "owner": {
    "name": "Yingte Xu",
    "email": "lucianoxu@foxmail.com"
  },
  "plugins": [
    {
      "name": "lean4-lake-lsp",
      "description": "Lean 4 language server via Lake — for Lake projects with dependencies (e.g., Mathlib). Provides diagnostics, hover info, go-to-definition, and completions for .lean files.",
      "version": "0.1.0",
      "author": {
        "name": "Yingte Xu",
        "email": "lucianoxu@foxmail.com"
      },
      "source": "./plugins/lean4-lsp",
      "category": "development",
      "tags": ["lean", "lean4", "theorem-proving", "mathematics", "formal-verification", "lake"],
      "repository": "https://github.com/LucianoXu/claude-lean4-lsp",
      "license": "MIT",
      "strict": false,
      "lspServers": {
        "lean": {
          "command": "lake",
          "args": ["serve"],
          "extensionToLanguage": {
            ".lean": "lean"
          },
          "startupTimeout": 60000,
          "maxRestarts": 3
        }
      }
    },
    {
      "name": "lean4-lean-lsp",
      "description": "Lean 4 language server via the lean binary — for standalone .lean files outside Lake projects. Provides diagnostics, hover info, go-to-definition, and completions.",
      "version": "0.1.0",
      "author": {
        "name": "Yingte Xu",
        "email": "lucianoxu@foxmail.com"
      },
      "source": "./plugins/lean4-lsp",
      "category": "development",
      "tags": ["lean", "lean4", "theorem-proving", "mathematics", "formal-verification", "standalone"],
      "repository": "https://github.com/LucianoXu/claude-lean4-lsp",
      "license": "MIT",
      "strict": false,
      "lspServers": {
        "lean": {
          "command": "lean",
          "args": ["--server"],
          "extensionToLanguage": {
            ".lean": "lean"
          },
          "startupTimeout": 60000,
          "maxRestarts": 3
        }
      }
    }
  ]
}
